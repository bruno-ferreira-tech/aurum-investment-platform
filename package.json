{
  "name": "aurum",
  "version": "1.0.0",
  "description": "Aurum - Premium Investment Platform Monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --workspace=apps/backend run start:dev",
    "dev:frontend": "npm --workspace=apps/frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm --workspace=apps/backend run build",
    "build:frontend": "npm --workspace=apps/frontend run build",
    "start": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm --workspace=apps/backend run start:prod",
    "start:frontend": "npm --workspace=apps/frontend run start",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm --workspace=apps/backend run lint",
    "lint:frontend": "npm --workspace=apps/frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
